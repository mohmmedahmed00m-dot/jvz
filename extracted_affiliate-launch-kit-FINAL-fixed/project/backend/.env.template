# =============================================================================
# Affiliate Launch Kit — ملف المتغيرات البيئية
# انسخ هذا الملف إلى .env وعبئه بقيمك الحقيقية
# لا ترفع ملف .env أبداً على GitHub أو أي مكان عام
# =============================================================================

# ─── قاعدة البيانات ──────────────────────────────────────────────────────────
# رابط PostgreSQL — المنصة (Railway/Render) تعطيك هذا تلقائياً
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/affiliate_launch_kit

# ─── Redis ───────────────────────────────────────────────────────────────────
# رابط Redis — المنصة تعطيك هذا تلقائياً
REDIS_URL=redis://HOST:6379

# ─── المصادقة (JWT) ──────────────────────────────────────────────────────────
# توليد قيمة عشوائية: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── التشفير ─────────────────────────────────────────────────────────────────
# مفتاح تشفير البيانات في قاعدة البيانات (AES-256-GCM)
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# تحذير: لو غيّرته بعد النشر تصبح البيانات القديمة غير قابلة للقراءة
ENCRYPTION_KEY=

# مفتاح HMAC للبحث السريع في البيانات المشفرة
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HASH_SECRET=

# ─── مزوّد الذكاء الاصطناعي ──────────────────────────────────────────────────
# الخيارات: groq | anthropic | openai | gemini
AI_PROVIDER=groq
AI_USE_REAL_LLM=true

# Groq (مجاني — الأسرع للبداية) — سجّل على console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude — سجّل على console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — سجّل على platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini — سجّل على aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── البريد الإلكتروني (Resend) ──────────────────────────────────────────────
# سجّل على resend.com للحصول على المفتاح — مجاني حتى 3000 بريد/شهر
EMAIL_PROVIDER_API_KEY=
# عنوان الإرسال — يجب توثيق الدومين في Resend
# للاختبار فقط استخدم: onboarding@resend.dev
EMAIL_FROM_ADDRESS=onboarding@resend.dev

# ─── JVZoo ───────────────────────────────────────────────────────────────────
# من لوحة تحكم JVZoo: Vendor → Settings → Secret Key
JVZOO_SECRET_KEY=

# ─── التخزين S3 (اختياري) ────────────────────────────────────────────────────
# إذا تركته فارغاً يُخزَّن محلياً على الخادم
# Cloudflare R2 مجاني حتى 10GB — الأفضل للبداية
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# ─── إعدادات التطبيق ─────────────────────────────────────────────────────────
# رابط الواجهة الأمامية — غيّره لدومينك الحقيقي
FRONTEND_BASE_URL=https://your-domain.com
NODE_ENV=production
PORT=3000

# =============================================================================
# كيفية توليد المفاتيح العشوائية:
#
# افتح Terminal وشغّل هذا الأمر 4 مرات (لكل مفتاح مرة):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ضع كل ناتج في:
#   JWT_SECRET
#   JWT_REFRESH_SECRET
#   ENCRYPTION_KEY
#   HASH_SECRET
# =============================================================================
